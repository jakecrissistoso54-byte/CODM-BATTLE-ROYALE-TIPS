function randomTip(){

let tips = [
"Always use high ground.",
"Upgrade your armor early.",
"Carry smoke grenades.",
"Listen to footsteps carefully.",
"Stay inside the safe zone early."
];

let random = tips[Math.floor(Math.random()*tips.length)];

document.getElementById("tip").innerText = random;

}

function bestGun(){

